// Fichier de démonstration du plugin Kraken Rules
// Ouvre-le avec le plugin installé pour voir la coloration,
// la complétion (Ctrl+Espace), les inspections et la navigation (Ctrl+B).

Namespace Policy

/**
 * Contexte racine de la police.
 */
Root Context Policy {
    String policyCd
    String state
    Child AddressInfo
}

Context AddressInfo {
    String postalCode
    String state
}

Dimension "state" : String

@Dimension("state", "CA")
Rule "Set AddressInfo.postalCode to state name" On AddressInfo.postalCode {
    Reset To "CA"
}

Rule "Policy code is mandatory" On Policy.policyCd {
    Set Mandatory
    Error "policy_cd_mandatory" : "Le code de la police est obligatoire"
}

Rule "Effective date in the past" On Policy.effectiveDate {
    Description "La date d'effet doit être passée"
    Priority 10
    When Policy.policyCd != null
    Assert effectiveDate < Today()
    Error "date_code" : "La date doit être dans le passé"
    Overridable
}

// Ctrl+B sur les noms ci-dessous pour naviguer vers les règles.
// Une référence inconnue est soulignée par l'inspection.
EntryPoint "Validation" {
    "Policy code is mandatory",
    "Effective date in the past"
}

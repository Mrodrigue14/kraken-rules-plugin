<idea-plugin>
    <id>io.github.mrodrigue14.kraken-rules</id>
    <name>Kraken Rules</name>
    <vendor email="masterketchup144@gmail.com">Miguel</vendor>

    <description><![CDATA[
        Language support for Kraken <code>.rules</code> files
        (<a href="https://github.com/eisgroup/kraken-rules">eisgroup/kraken-rules</a> DSL).
        <ul>
            <li>Syntax highlighting</li>
            <li>Code completion (keywords, payloads, @Dimension, rule names)</li>
            <li>Inspections (rule without name, unresolved rule reference)</li>
            <li>Intention: add missing 'On' clause</li>
            <li>Navigation between EntryPoint items and Rule declarations</li>
            <li>Rename refactoring for rules</li>
        </ul>
        <p><i>This is an independent community plugin. It is not affiliated with,
        endorsed by, or sponsored by EIS Group. "Kraken" refers to the open-source
        Kraken Rules engine (Apache-2.0).</i></p>
    ]]></description>

    <change-notes><![CDATA[
        <b>0.2.0</b>
        <ul>
            <li>Structure view, code folding, code formatter and live templates (rule, ep, ctx, dim).</li>
            <li>Field completion after "On Context." (inheritance-aware).</li>
            <li>Namespace-aware resolution (Namespace / Include).</li>
            <li>Gutter icon on rules referenced by entry points.</li>
            <li>Quick documentation (Ctrl+Q) for rules.</li>
            <li>New inspections: unknown context, duplicate rule, unused rule, undeclared dimension.</li>
        </ul>
        <b>0.1.0</b>
        <ul>
            <li>Initial release: syntax highlighting, code completion, inspections,
            intention action, navigation and rename refactoring for Kraken .rules files.</li>
            <li>Grammar validated against the full test corpus of the official
            eisgroup/kraken-rules repository.</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="Kraken Rules"
                implementationClass="com.kraken.plugin.lang.KrakenFileType"
                fieldName="INSTANCE"
                language="Kraken"
                extensions="rules"/>

        <lang.parserDefinition
                language="Kraken"
                implementationClass="com.kraken.plugin.lang.KrakenParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="Kraken"
                implementationClass="com.kraken.plugin.highlighter.KrakenSyntaxHighlighterFactory"/>

        <colorSettingsPage
                implementation="com.kraken.plugin.highlighter.KrakenColorSettingsPage"/>

        <lang.commenter
                language="Kraken"
                implementationClass="com.kraken.plugin.lang.KrakenCommenter"/>

        <lang.braceMatcher
                language="Kraken"
                implementationClass="com.kraken.plugin.lang.KrakenBraceMatcher"/>

        <completion.contributor
                language="Kraken"
                implementationClass="com.kraken.plugin.completion.KrakenCompletionContributor"/>

        <lang.findUsagesProvider
                language="Kraken"
                implementationClass="com.kraken.plugin.navigation.KrakenFindUsagesProvider"/>

        <gotoDeclarationHandler
                implementation="com.kraken.plugin.navigation.KrakenGotoDeclarationHandler"/>

        <lang.elementManipulator
                forClass="com.kraken.plugin.psi.KrakenRuleRef"
                implementationClass="com.kraken.plugin.psi.KrakenRuleRefManipulator"/>

        <localInspection
                language="Kraken"
                shortName="KrakenRuleWithoutName"
                displayName="Rule without name"
                groupName="Kraken"
                enabledByDefault="true"
                level="ERROR"
                implementationClass="com.kraken.plugin.inspection.KrakenRuleWithoutNameInspection"/>

        <localInspection
                language="Kraken"
                shortName="KrakenUnresolvedRuleReference"
                displayName="Unresolved rule reference in entry point"
                groupName="Kraken"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="com.kraken.plugin.inspection.KrakenUnresolvedRuleRefInspection"/>

        <intentionAction>
            <language>Kraken</language>
            <className>com.kraken.plugin.inspection.KrakenAddOnClauseIntention</className>
            <category>Kraken</category>
        </intentionAction>

        <lang.psiStructureViewFactory
                language="Kraken"
                implementationClass="com.kraken.plugin.structure.KrakenStructureViewFactory"/>

        <lang.foldingBuilder
                language="Kraken"
                implementationClass="com.kraken.plugin.structure.KrakenFoldingBuilder"/>

        <lang.formatter
                language="Kraken"
                implementationClass="com.kraken.plugin.formatter.KrakenFormattingModelBuilder"/>

        <codeInsight.lineMarkerProvider
                language="Kraken"
                implementationClass="com.kraken.plugin.navigation.KrakenRuleUsagesLineMarkerProvider"/>

        <lang.documentationProvider
                language="Kraken"
                implementationClass="com.kraken.plugin.documentation.KrakenDocumentationProvider"/>

        <liveTemplateContext
                contextId="KRAKEN"
                implementation="com.kraken.plugin.completion.KrakenTemplateContext"/>
        <defaultLiveTemplates file="/liveTemplates/Kraken"/>

        <localInspection
                language="Kraken"
                shortName="KrakenUnknownContext"
                displayName="Unknown context in 'On' clause"
                groupName="Kraken"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="com.kraken.plugin.inspection.KrakenUnknownContextInspection"/>

        <localInspection
                language="Kraken"
                shortName="KrakenDuplicateRule"
                displayName="Duplicate rule without differentiating dimension"
                groupName="Kraken"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="com.kraken.plugin.inspection.KrakenDuplicateRuleInspection"/>

        <localInspection
                language="Kraken"
                shortName="KrakenUnusedRule"
                displayName="Rule not referenced by any entry point"
                groupName="Kraken"
                enabledByDefault="true"
                level="WEAK WARNING"
                implementationClass="com.kraken.plugin.inspection.KrakenUnusedRuleInspection"/>

        <localInspection
                language="Kraken"
                shortName="KrakenUndeclaredDimension"
                displayName="Undeclared dimension in @Dimension annotation"
                groupName="Kraken"
                enabledByDefault="true"
                level="WEAK WARNING"
                implementationClass="com.kraken.plugin.inspection.KrakenUndeclaredDimensionInspection"/>
    </extensions>
</idea-plugin>
